# --- Môi trường Python & Venv ---
venv/
env/
__pycache__/
*.py[cod]

# --- Ren'Py Engine & Cache ---
# Ren'Py tự tạo ra các file .rpyc, .rpymc khi chạy game, không cần đẩy lên Git
game/**/*.rpyc
game/**/*.rpymc
game/**/*.rpyb
game/**/*.rpyo

# --- Thư mục lưu game và log ---
game/saves/
log.txt
errors.txt
traceback.txt
temp/

# --- File hệ thống & OS ---
.DS_Store
Thumbs.db

# --- Bản build (nếu bạn export ra) ---
builds/
dist/